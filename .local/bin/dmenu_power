#!/bin/bash
# Author: Achmad Fauzi

cmd="rofi -dmenu -i -p System"
# Options
shutdown="ţžÇ Shutdown"
reboot="ţžä Reboot"
lock="ţŽĆ Lock"
suspend="ţŽú Suspend"
logout="ţŽĹ Logout"

options="$shutdown\n$reboot\n$lock\n$suspend\n$logout"
chosen="$(echo -e "$options" | $cmd)"
case $chosen in
    $shutdown)
			systemctl poweroff
			;;
    $reboot)
			systemctl reboot
			;;
    $lock)
			mantablockscreen -cc
        		;;
    $suspend)
			mpc -q pause
			amixer set Master mute
			betterlockscreen -l dimblur
			systemctl suspend
			;;
    $logout)
				i3-msg exit
				;;
esac
